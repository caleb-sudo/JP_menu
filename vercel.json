{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node" 
        },
        {
            "src": "ordersServer.js",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "dest": "server.js"
        },
        {
            "source": "/(.*)",
            "destination": "ordersServer.js"
        }
    ]
}